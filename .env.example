# BrainVision environment configuration
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_USER=brainvision
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=brainvision

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-a-32-char-minimum-random-string

# Application
DEBUG=false

# Model (place your .h5 file in the models/ directory)
MODEL_PATH=/app/models/inception_v3_brain_tumor.h5
